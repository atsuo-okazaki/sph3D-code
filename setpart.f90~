               ELSE IF (icoord == 2) THEN
                  CALL cyldis
               ELSE
                  CALL sphdis(igeom, idist, np ,h1, facx, facy, facz, &
                            delx, dely, nx, ny, nz)
               ENDIF
            ENDIF
         ENDIF
         if(myrank == 0)WRITE (*, *) 'npart=',npart
      ELSE
