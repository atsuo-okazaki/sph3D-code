88115    FORMAT(/,'   How many particles from end start fast dumping?')
         READ (*,*) nfastd
      ENDIF
      IF (ibound >= 90) THEN
         IF (ibound == 90 .OR. ibound == 91) THEN
            if(myrank == 0)WRITE(*,88113)
            READ (*,*) deadbound
            if(myrank == 0)WRITE(*,88116)
88116       FORMAT(/,'   How many particles in shell', &
