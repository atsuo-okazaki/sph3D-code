            READ (*,*) partmratio

!!            rmind = rptmas(1)
            nshell1(1) = NINT(nshell/(1.0+emdotratio/partmratio))
            nshell1(2) = nshell - nshell1(1)
            sinj0(1) = 0.0
            sinj0(2) = 0.0
            rshell = rshell1
            if(myrank == 0) &
            WRITE (*,*) 'nshell=',nshell,': nshell1(1)=',nshell1(1), &
