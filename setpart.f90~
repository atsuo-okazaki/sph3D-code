!--Set Uniform Density Distribution
!
         CALL unifdis(igeom, idist, np, h1, facx, facy, facz, &
                         delx, dely, nx, ny, nz, ibound)
         IF (notdone == 1) GOTO 400
 575     if(myrank == 0)WRITE(*, 99105)
