      SUBROUTINE ghostp3(npart, x, y, z, vx, vy, vz, u, h)
!************************************************************
!                                                           *
!  This subroutine computes the list of ghost particles for *
!     treating the boundaries.                              *
!                                                           *
!************************************************************

      use idims

      use constants
      use carac
      use ghost
      use densi
      use rbnd
      use diskbd
      use logun
      use debug
      use phase
      use ptmass
      use crpart
      use kerne
      use typef
      use sphcom

      implicit none

      INTEGER :: npart, i, iinner, nptot, ntot, ipt
      REAL(kind=DBL) :: x(idim), y(idim), z(idim)
      REAL(kind=DBL) :: vx(idim), vy(idim), vz(idim), h(idim), u(idim)
      REAL(kind=DBL) :: delta, delta2, drmax, drmax2, &
               drmin, drmin2, drref, dzmax, dzmin, hi, hi2, pmassi, &
               r, r2, rcyl2, rmax2, rmind2, drmind2, rhoi, &
               vr, vxr, vyr, vzr, vxc, vyc, vzc, xc, yc, zc, ui, &
               vxi, vyi, vzi, xi, yi, zi, xir, yir, zir, fghost
      CHARACTER(len=7) :: where='ghostp3'
!
!--Allow for tracing flow
!
!!      IF (myrank.eq.0) THEN
         IF (itrace == 'all') WRITE (iprint, 99001)
99001    FORMAT (' entry subroutine ghostp3')
!!      ENDIF

      nghost = 0
      inshell = 0
!
!--If ibound = 3, 8, 96 or 97 then we have spherical boundaries
!--now find ghost for spherical boundaries
!
!!      IF (myrank.eq.0)  THEN
!!         WRITE (iprint, *) 'ibound =',ibound,' isphcom =',isphcom
!!      END IF
      IF (ibound == 3 .AND. isphcom /= 0) THEN
!!         rmind2 = rmind*rmind
         rmind2 = rptmas(isphcom)*rptmas(isphcom)
         xc = x(isphcom)
         yc = y(isphcom)
         zc = z(isphcom)
         vxc = vx(isphcom)
         vyc = vy(isphcom)
         vzc = vz(isphcom)
!!         DO i = 1, npart
         DO i = nptmass+1, npart
            hasghost(i) = 0
            IF (iphase(i) /= 0) CYCLE

            xi = x(i)-xc
            yi = y(i)-yc
            zi = z(i)-zc

            vxi = vx(i)-vxc
            vyi = vy(i)-vyc
            vzi = vz(i)-vzc

            hi = h(i)
            pmassi = pmass(i)
            rhoi = rho(i)
            ui = u(i)

!!            delta = 0.001*hi
!!            delta = MIN(0.001*hi,rmind*0.01)
            delta = MIN(0.001*hi,rptmas(isphcom)*0.01)
            hi2 = hi*hi
            r2 = xi*xi + yi*yi + zi*zi + tiny
            delta2 = delta*delta
!!            drmin = rmind + radkernel*hi
            drmin = rptmas(isphcom) + radkernel*hi
            drmin2 = drmin*drmin
!!            drmind2 = rmind2 + delta2 + 2*rmind*delta
            drmind2 = rmind2 + delta2 + 2*rptmas(isphcom)*delta

!-- Count the number of particles in the shell
            IF (r2 > rmind2 .AND. r2 < rshell*rshell) &
               inshell = inshell + 1

!!            IF (myrank.eq.0) THEN
!!               WRITE (iprint,*) 'r2 =',r2,' (rmind2 =',rmind2,')'
!!               WRITE (iprint,*) 'inshell =',inshell, &
!!                                ' in r<rshell (',rshell,')'
!!            ENDIF
!-- Create a new ghost particle
            IF (r2 < drmin2 .AND. r2 > drmind2) THEN
               hasghost(i) = 1
               nghost = nghost + 1
               nptot = MIN0(npart + nghost, idim)
               ireal(nptot) = i

               r = SQRT(r2)
!!               rg = 2*rmind - r
               rg = 2*rptmas(isphcom) - r
               xi = xi/r*rg
               yi = yi/r*rg
               zi = zi/r*rg
               r = rg

               vr = (vxi*xi + vyi*yi + vzi*zi)/r
               vxi = vxi - 2.0*vr*xi/r
               vyi = vyi - 2.0*vr*yi/r
               vzi = vzi - 2.0*vr*zi/r

               x(nptot) = xi + xc
               y(nptot) = yi + yc
               z(nptot) = zi + zc
               vx(nptot) = vxi + vxc
               vy(nptot) = vyi + vyc
               vz(nptot) = vzi + vzc

               h(nptot) = hi
               pmass(nptot) = pmassi
               rho(nptot) = rhoi
               u(nptot) = ui
               iphase(nptot) = 0
            ENDIF
         ENDDO
      ELSE IF (ibound == 8) THEN
         rmax2 = rmax*rmax
         DO i = 1, npart
            hasghost(i) = 0
            IF (iphase(i) /= 0) CYCLE

            xi = x(i)
            yi = y(i)
            zi = z(i)

            vxi = vx(i)
            vyi = vy(i)
            vzi = vz(i)

            hi = h(i)
            pmassi = pmass(i)
            rhoi = rho(i)
            ui = u(i)

            delta = 0.001*hi
            hi2 = hi*hi
            r2 = xi*xi + yi*yi + zi*zi + tiny
            delta2 = delta*delta
            drmin = rmax - radkernel*hi
            drmin2 = drmin*drmin
            drmax2 = rmax2 + delta2 - 2*rmax*delta

            IF (r2 > rshell*rshell) inshell = inshell + 1

            IF (r2 > drmin2 .AND. r2 < drmax2) THEN
               hasghost(i) = 1
               nghost = nghost + 1
               nptot = MIN0(npart + nghost, idim)
               ireal(nptot) = i

               r = SQRT(r2)
               rg = 2*rmax - r
               xir = xi/r
               yir = yi/r
               zir = zi/r
               x(nptot) = xir*rg
               y(nptot) = yir*rg
               z(nptot) = zir*rg

               vr = vxi*xir + vyi*yir + vzi*zir
               vxr = vr*xir
               vyr = vr*yir
               vzr = vr*zir
               vx(nptot) = vxi - 2*vxr
               vy(nptot) = vyi - 2*vyr
               vz(nptot) = vzi - 2*vzr

               h(nptot) = hi
               pmass(nptot) = pmassi
               rho(nptot) = rhoi
               u(nptot) = ui
               iphase(nptot) = 0
            ENDIF
         ENDDO
      ELSEIF (ibound == 96 .OR. ibound == 97) THEN
         DO ipt = 1,nptmass
            rmind2 = rptmas(ipt)*rptmas(ipt)
            xc = x(ipt)
            yc = y(ipt)
            zc = z(ipt)
            vxc = vx(ipt)
            vyc = vy(ipt)
            vzc = vz(ipt)
            DO i = nptmass+1, npart
               hasghost(i) = 0
               IF (iphase(i) /= 0) CYCLE

               xi = x(i)-xc
               yi = y(i)-yc
               zi = z(i)-zc

               vxi = vx(i)-vxc
               vyi = vy(i)-vyc
               vzi = vz(i)-vzc

               hi = h(i)
               pmassi = pmass(i)
               rhoi = rho(i)
               ui = u(i)

!!               delta = 0.001*hi
               delta = MIN(0.001*hi,rptmas(ipt)*0.01)
               hi2 = hi*hi
               r2 = xi*xi + yi*yi + zi*zi + tiny
               vr = (vxi*xi + vyi*yi + vzi*zi)/SQRT(r2)
               delta2 = delta*delta
               drmin = rptmas(ipt) + radkernel*hi
               drmin2 = drmin*drmin
               drmind2 = rmind2 + delta2 + 2*rptmas(ipt)*delta

!-- Count the number of particles in the shell
               IF (r2 > rmind2 .AND. r2 < rshell*rshell) &
                  inshell = inshell + 1

!!                  IF (myrank.eq.0) THEN
!!                     WRITE (iprint,*) 'r2 =',r2,' (rmind2 =', &
!!                             rmind2,')'
!!                     WRITE (iprint,*) 'inshell =',inshell, &
!!                             ' in r<rshell (',rshell,')'
!!                  ENDIF
!-- Create a new ghost particle
               IF (r2 < drmin2 .AND. r2 > drmind2 &
               .AND. vr < 0.0) THEN
                  hasghost(i) = 1
                  nghost = nghost + 1
                  nptot = MIN0(npart + nghost, idim)
                  ireal(nptot) = i

                  r = SQRT(r2)
                  rg = 2*rptmas(ipt) - r
                  xi = xi/r*rg
                  yi = yi/r*rg
                  zi = zi/r*rg
                  r = rg

!----             Velocity components of the ghost particle:
!                   radial velocity = fghost*|vr| (0<=fghost<=1),
!                   where fghost=1.0 is for a reflecting boundary
!                   and fghost=0.0 is for no radial motion, and
!                   tangential velocity = that of the SPH particle.
                  fghost = 0.0
!!                  fghost = 1.0
                  vr = (vxi*xi + vyi*yi + vzi*zi)/r
                  vxi = vxi - (1.0+fghost)*vr*xi/r
                  vyi = vyi - (1.0+fghost)*vr*yi/r
                  vzi = vzi - (1.0+fghost)*vr*zi/r

                  x(nptot) = xi + xc
                  y(nptot) = yi + yc
                  z(nptot) = zi + zc
                  vx(nptot) = vxi + vxc
                  vy(nptot) = vyi + vyc
                  vz(nptot) = vzi + vzc

                  h(nptot) = hi
                  pmass(nptot) = pmassi
                  rho(nptot) = rhoi
                  u(nptot) = ui
                  iphase(nptot) = 0
               ENDIF
            ENDDO
         ENDDO
      ENDIF

!! 100  IF (myrank.eq.0)  WRITE (iprint, 99002) nghost, inshell
!!99002 FORMAT (' nghost =',I8,' (inshell =',I8,')')

      ntot = npart + nghost
      IF (ntot > idim) CALL error(where, ntot)

      END SUBROUTINE ghostp3
